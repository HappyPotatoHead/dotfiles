(defpoll music-player     :interval "1s" "~/.config/eww/scripts/media_controller.sh --player")
(defpoll music-art        :interval "3s" "~/.config/eww/scripts/media_controller.sh --cover")
(defpoll music-title      :interval "1s" "~/.config/eww/scripts/media_controller.sh --title")
(defpoll music-artist     :interval "1s" "~/.config/eww/scripts/media_controller.sh --artist")
(defpoll music-status     :interval "1s" "~/.config/eww/scripts/media_controller.sh --status")
(defpoll music-position   :interval "1s" "~/.config/eww/scripts/media_controller.sh --position")
(defpoll music-positions  :interval "1s" "~/.config/eww/scripts/media_controller.sh --positions")
(defpoll music-length     :interval "1s" "~/.config/eww/scripts/media_controller.sh --length")
(defpoll music-lengths    :interval "1s" "~/.config/eww/scripts/media_controller.sh --lengths")
(defpoll shuffle          :interval "1s" "~/.config/eww/scripts/media_controller.sh --shuffle")
(defpoll loop             :interval "1s" "~/.config/eww/scripts/media_controller.sh --loop")


